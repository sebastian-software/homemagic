{
  "schema": "automation.document.v1",
  "id": "018f7f88-82f8-4d0a-8d85-1de2ca4cb001",
  "version": 1,
  "name": "Keep shared lights comfortable",
  "provenance": {
    "author_id": "018f7f88-82f8-4d0a-8d85-1de2ca4cb002",
    "agent_id": "home-agent",
    "source_request": "Keep the shared lights comfortable and avoid flicker.",
    "rationale": "React to state and schedule changes while reducing repeated targets."
  },
  "variables": {
    "target_level": {
      "value_type": "integer",
      "initial": {"type": "integer", "value": 45}
    }
  },
  "triggers": [
    {
      "type": "observation_changed",
      "target": {
        "device": {"selector": "alias", "alias": "Shared light"},
        "endpoint_id": null,
        "capability": "on_off.v1"
      },
      "field": "on"
    },
    {
      "type": "device_event",
      "target": {
        "device": {"selector": "device", "device_id": "018f7f88-82f8-4d0a-8d85-1de2ca4cb003"},
        "endpoint_id": "input:0",
        "capability": "button.v1"
      },
      "event": "single_push"
    },
    {
      "type": "schedule",
      "schedule": {"cron": "0 18 * * *", "timezone": "Europe/Berlin", "occurrence_window_ms": 60000}
    },
    {
      "type": "command_outcome",
      "target": {
        "device": {"selector": "space", "space_id": "018f7f88-82f8-4d0a-8d85-1de2ca4cb004"},
        "endpoint_id": null,
        "capability": "on_off.v1"
      },
      "states": ["confirmed", "failed"]
    }
  ],
  "condition": {
    "type": "all",
    "conditions": [
      {
        "type": "compare",
        "left": {"source": "variable", "name": "target_level"},
        "operator": "greater_than",
        "right": {"source": "literal", "value": {"type": "integer", "value": 0}}
      },
      {
        "type": "any",
        "conditions": [
          {"type": "literal", "value": true},
          {"type": "not", "condition": {"type": "literal", "value": false}}
        ]
      },
      {"type": "time_window", "timezone": "Europe/Berlin", "start": "06:00:00", "end": "23:00:00"},
      {"type": "state_duration", "condition": {"type": "literal", "value": true}, "duration_ms": 1000}
    ]
  },
  "actions": [
    {
      "type": "command",
      "target": {
        "device": {"selector": "alias", "alias": "Shared light"},
        "endpoint_id": null,
        "capability": "on_off.v1"
      },
      "payload": {"capability": "on_off", "command": {"action": "set", "on": true}},
      "retry": {"maximum_retries": 0, "backoff_ms": 0, "retryable_command_errors": []},
      "on_failure": {"mode": "stop_run"}
    },
    {"type": "delay", "duration_ms": 250},
    {
      "type": "wait",
      "condition": {
        "type": "compare",
        "left": {
          "source": "observation",
          "target": {
            "device": {"selector": "alias", "alias": "Shared light"},
            "endpoint_id": null,
            "capability": "on_off.v1"
          },
          "field": "on"
        },
        "operator": "equal",
        "right": {"source": "literal", "value": {"type": "boolean", "value": true}}
      },
      "timeout_ms": 5000,
      "on_timeout": {"mode": "continue"}
    },
    {"type": "set_variable", "name": "target_level", "value": {"source": "literal", "value": {"type": "integer", "value": 40}}},
    {"type": "sequence", "actions": [{"type": "delay", "duration_ms": 1}]},
    {
      "type": "if",
      "condition": {"type": "literal", "value": true},
      "then_actions": [{"type": "delay", "duration_ms": 1}],
      "else_actions": [{"type": "delay", "duration_ms": 2}]
    },
    {
      "type": "parallel",
      "branches": [[{"type": "delay", "duration_ms": 1}], [{"type": "delay", "duration_ms": 2}]],
      "maximum_parallel": 2
    },
    {
      "type": "race",
      "branches": [[{"type": "delay", "duration_ms": 1}], [{"type": "delay", "duration_ms": 2}]],
      "maximum_parallel": 2
    },
    {
      "type": "command",
      "target": {
        "device": {"selector": "alias", "alias": "Shared light"},
        "endpoint_id": null,
        "capability": "on_off.v1"
      },
      "payload": {"capability": "on_off", "command": {"action": "set", "on": false}},
      "retry": {"maximum_retries": 1, "backoff_ms": 100, "retryable_command_errors": ["transport_failure"]},
      "on_failure": {"mode": "fallback", "actions": [{"type": "delay", "duration_ms": 1}]}
    }
  ],
  "run_mode": {"mode": "queued", "capacity": 16},
  "self_trigger": "suppress_same_version",
  "budget": {
    "maximum_nodes": 512,
    "maximum_nesting_depth": 16,
    "maximum_parallel_width": 8,
    "maximum_queue_length": 128,
    "maximum_trace_steps": 10000,
    "maximum_run_duration_ms": 604800000
  },
  "created_at": "2026-07-11T12:00:00Z"
}
