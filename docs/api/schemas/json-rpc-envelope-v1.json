{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homemagic.dev/schemas/json-rpc-envelope-v1.json",
  "title": "HomeMagic JSON-RPC envelope v1",
  "schemas": {
    "request": {
      "type": "object",
      "properties": {
        "jsonrpc": { "const": "2.0" },
        "id": { "type": ["integer", "string"] },
        "method": { "type": "string", "minLength": 1 },
        "params": { "type": "object" }
      },
      "required": ["jsonrpc", "id", "method", "params"],
      "additionalProperties": false
    },
    "success": {
      "type": "object",
      "properties": {
        "jsonrpc": { "const": "2.0" },
        "id": { "type": ["integer", "string"] },
        "result": { "type": "object" }
      },
      "required": ["jsonrpc", "id", "result"],
      "additionalProperties": false
    },
    "error": {
      "type": "object",
      "properties": {
        "jsonrpc": { "const": "2.0" },
        "id": { "type": ["integer", "string"] },
        "error": {
          "type": "object",
          "properties": {
            "code": { "type": "integer" },
            "message": { "type": "string", "minLength": 1 },
            "data": {
              "type": "object",
              "properties": { "code": { "type": "string", "minLength": 1 } },
              "required": ["code"],
              "additionalProperties": false
            }
          },
          "required": ["code", "message", "data"],
          "additionalProperties": false
        }
      },
      "required": ["jsonrpc", "id", "error"],
      "additionalProperties": false
    }
  }
}
